rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isTeacher() {
      return isAuthenticated() && getUserRole() == 'teacher';
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "rahulraj000019@gmail.com" && request.auth.token.email_verified == true));
    }

    // User profiles
    match /users/{uid} {
      allow read: if isAuthenticated();
      // Allow creation for self
      allow create: if isOwner(uid) && (request.resource.data.role == 'student' || request.resource.data.role == 'teacher');
      // Allow update for self, but NOT the role field unless admin
      allow update: if isAdmin() || (isOwner(uid) && request.resource.data.role == resource.data.role);
      // Admin can do anything
      allow delete: if isAdmin();
    }

    // Exams
    match /exams/{examId} {
      allow read: if isAuthenticated();
      allow create: if isTeacher() || isAdmin();
      allow update, delete: if isAdmin() || (isTeacher() && resource.data.creatorUid == request.auth.uid);
      
      match /questions/{questionId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin() || isTeacher();
      }
    }

    // Submissions
    match /submissions/{submissionId} {
      allow read: if isAuthenticated() && (resource.data.studentUid == request.auth.uid || isTeacher() || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (resource.data.studentUid == request.auth.uid || isTeacher() || isAdmin());
      
      match /logs/{logId} {
        allow read: if isAuthenticated() && (get(/databases/$(database)/documents/submissions/$(submissionId)).data.studentUid == request.auth.uid || isTeacher() || isAdmin());
        allow create: if isAuthenticated();
      }
    }
  }
}
